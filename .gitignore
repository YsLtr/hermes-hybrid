# .gitignore for Hermes Hybrid

# Rust
/gateway/target/
**/*.rs.bk
*.pdb
Cargo.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.log

# Virtual environments
agent/venv/
agent/.venv/
agent/env/
agent/ENV/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Configuration files (contains secrets)
config.yaml
.env
*.local.yaml

# Logs
*.log
logs/

# Database
*.db
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
*.tmp

# systemd runtime
*.pid

# Testing
.pytest_cache/
.coverage
htmlcov/

# Documentation builds
docs/_build/
